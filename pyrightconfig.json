{
    "include": [
        "backend"
    ],
    "exclude": [
        "**/node_modules",
        "**/__pycache__",
        "**/venv",
        "**/.venv"
    ],
    "venvPath": "backend",
    "venv": "venv",
    "pythonPath": "backend/venv/bin/python",
    "pythonVersion": "3.13",
    "typeCheckingMode": "basic",
    "useLibraryCodeForTypes": true,
    "autoImportCompletions": true,
    "extraPaths": [
        "backend"
    ]
}
